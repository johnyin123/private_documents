#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdarg.h>
#if defined(__WIN32__)
    #include <winsock2.h>
    #include <ws2tcpip.h>
    typedef int socklen_t;
    #define close_socket closesocket
    #define sock_read(a,b,c)  recv(a,b,c,0)
    #define sock_write(a,b,c) send(a,b,c,0)
#else
    #define close_socket close
    #define sock_read(a,b,c)  read(a,b,c)
    #define sock_write(a,b,c) write(a,b,c)
    #include <sys/socket.h>
    #include <arpa/inet.h>
    #include <unistd.h>
    #include <netinet/tcp.h>
    #include <fcntl.h>
    #include <signal.h>
    #include <errno.h>
#endif
#ifdef DEBUG
    #define debugln(format,args...) fprintf(stderr, "%s:%d == "format"\n", __FILE__, __LINE__, ##args)
#else
    #define debugln(...) do {} while (0)
#endif
#define XSTR(s)       STR(s)
#define STR(s)        #s
#define HTTP_PORT     8080
#define MAX_CONNS     64  /* < FD_SETSIZE */
#define METHOD_LEN    8
#define URI_LEN       2048
#define MAX_HEADERS   8
#define HDR_KEY_LEN   16
#define HDR_VAL_LEN   256
/*############################################################*/
#if defined(__WIN32__)
void* memmem(const void* haystack, size_t haystacklen, const void* needle, size_t needlelen) {
    if(!needlelen) return (void*)haystack;
    for(size_t i = 0; i + needlelen <= haystacklen; i++) {
        if(!memcmp((char*)haystack + i, needle, needlelen)) return (char*)haystack + i;
    }
    return NULL;
}
#endif
static int set_sock_nonblock_nodelay(int fd) {
    setsockopt(fd, IPPROTO_TCP, TCP_NODELAY, (void *)&(int){1}, sizeof(int));
#if defined(__WIN32__)
    unsigned long mode = 1;
    return ioctlsocket(fd, FIONBIO, &mode);
#else
    int flags = fcntl(fd, F_GETFL);
    return (flags < 0) ? -1 : fcntl(fd, F_SETFL, flags | O_NONBLOCK);
#endif
}
static int create_tcp_server(const char *addr, int port, int backlog) {
    int srv_sock;
    struct sockaddr_in sa = { .sin_family = AF_INET, .sin_addr.s_addr = inet_addr(addr), .sin_port = htons(port) };
    if ((srv_sock = socket(AF_INET, SOCK_STREAM, 0)) == -1) return -1;
    setsockopt(srv_sock, SOL_SOCKET, SO_REUSEADDR, (void *)&(int){1}, sizeof(int));
    set_sock_nonblock_nodelay(srv_sock);
    if (bind(srv_sock,(struct sockaddr*)&sa,sizeof(sa)) == -1 || listen(srv_sock, backlog) == -1) {
        close_socket(srv_sock);
        return -1;
    }
    return srv_sock;
}
/*############################################################*/
#define BUF_SIZE      (8192 - sizeof(size_t))
struct buf_t {
    char buf[BUF_SIZE];
    size_t buf_len;
};
static inline int buf_printf(struct buf_t *b, const char *format, ...) {
    if(b->buf_len >= BUF_SIZE) return 0;
    va_list args;
    va_start(args, format);
    int n = vsnprintf(b->buf + b->buf_len, BUF_SIZE-b->buf_len-1, format, args);
    va_end(args);
    if(n>0) b->buf_len += n;
    return n;
}
static inline char* buf_find(struct buf_t *b, const char *needle, size_t len) {
    for(size_t i=0; i+len<=b->buf_len; i++) {
        if(memcmp(b->buf+i, needle, len) == 0)
            return b->buf+i;
    }
    return NULL;
}
static inline ssize_t buf_read_fd(struct buf_t *b, int fd, unsigned int *total) {
    if((BUF_SIZE - b->buf_len) <= 0) return -1;
    ssize_t n = sock_read(fd, b->buf + b->buf_len, BUF_SIZE - b->buf_len);
    if (n > 0) {
        b->buf_len += n;
        if(total) *total += n;
    }
    return n;
}
static inline ssize_t buf_write_fd(struct buf_t *b, int fd, unsigned int *total) {
    ssize_t n = sock_write(fd, b->buf, b->buf_len);
    if (n > 0) {
        b->buf_len -= n;
        if(total) *total += n;
        memmove(b->buf, b->buf + n, b->buf_len);
    }
    return n;
}
enum mime_t { JSON = 0, TEXT };
struct response_t {
    unsigned int status;
    enum mime_t mime;
    unsigned int header_len;
    unsigned int content_len;
    unsigned int total_len;
    struct buf_t buf;
};
struct hdr_prop_t {
    char key[HDR_KEY_LEN+1];
    char val[HDR_VAL_LEN+1];
};
struct request_t {
    char method[METHOD_LEN+1];
    char uri[URI_LEN+1];
    int vhi,vlo;
    size_t nprop;
    struct hdr_prop_t prop[MAX_HEADERS];
    unsigned int header_len;
    unsigned int content_len;
    unsigned int total_len;
    struct buf_t buf;
};
#define IDLE_TIMEOUT_COUNT 5
enum client_state_t { ST_UNUSED = 0, ST_READ, ST_HEAD, ST_BODY, ST_WRITE, };
struct client_t {
    int fd;
    void *ctx;
    int tick_cnt;
    int keep_alive;
    enum client_state_t state;
    struct request_t request;
    struct response_t response;
};
#define REQ_READ(c)     buf_read_fd(&(c->request.buf), c->fd, &(c->request.total_len))
#define RES_WRITE(c)    buf_write_fd(&(c->response.buf), c->fd, &(c->response.total_len))
static void dump_client(const struct client_t* c) {
    const char *state[]={"ST_UNUSED", "ST_READ", "ST_HEAD", "ST_BODY", "ST_WRITE"};
    fprintf(stderr, "socket %d %s keepalive=%d ctx=%p, ticket count %d\n", c->fd, state[c->state], c->keep_alive, (void *)c->ctx, c->tick_cnt);
    fprintf(stderr, "  %s HTTP(%d.%d) %s\n", c->request.method, c->request.vhi, c->request.vlo, c->request.uri);
    for(int i=0;i<c->request.nprop;i++) fprintf(stderr, "    [%d] %s: %s\n", i+1, c->request.prop[i].key, c->request.prop[i].val);
    fprintf(stderr, "  REQUEST: HEADER(%d), CONTENT(%d), TOTAL(%d)\n", c->request.header_len, c->request.content_len, c->request.total_len);
    fprintf(stderr, "    REQ BUFFER: %ld\n", (long int)c->request.buf.buf_len);
    fprintf(stderr, "  RESPONSE(%d): HEADER(%d), CONTENT(%d), TOTAL(%d)\n", c->response.status, c->response.header_len, c->response.content_len, c->response.total_len);
    fprintf(stderr, "    RES BUFFER: %ld\n", (long int)c->response.buf.buf_len);
}
/*==================================================*/
#define SRV_INFO "Server: inner"
static const char *mime_str(enum mime_t m) {
    switch (m) {
        case JSON:       return "application/json";
        case TEXT:       return "text/plain; charset=utf-8";
        default:         return "application/octet-stream";
    }
}
static const char *status_str(unsigned int s) {
    switch (s) {
        case 200: return "200 OK";
        case 403: return "403 Forbidden";
        case 413: return "413 Content Too Large";
        case 404: return "404 Not Found";
        default:  return "500 Internal Server Error";
    }
}
static inline int make_header(struct client_t *c, unsigned int status, int mime, unsigned int content_len) {
    c->response.status = status;
    c->response.mime = mime;
    c->response.content_len = content_len;
    if (c->response.content_len <= 0) return -1;
    int ret  = snprintf(c->response.buf.buf+c->response.buf.buf_len, BUF_SIZE-c->response.buf.buf_len, "HTTP/1.1 %s\r\n%s\r\nContent-Type: %s\r\nConnection: %s\r\nContent-Length: %d\r\n\r\n", status_str(status), SRV_INFO, mime_str(mime), c->keep_alive ? "keep-alive" : "close", c->response.content_len);
    if (ret<=0 || ret > BUF_SIZE-c->response.buf.buf_len) return -2;
    c->response.header_len = ret;
    c->response.buf.buf_len += ret;
    return c->response.header_len;
}
static inline int make_response(struct client_t *c, unsigned int status, int mime, const char *format, ...) {
    int ret;
    va_list args;
    va_start(args, format);
    ret = vsnprintf(NULL, 0, format, args);
    va_end(args);
    if(ret<=0) return -3;
    ret = make_header(c, status, mime, ret);
    if(ret<=0) return ret;
    if (c->response.header_len + c->response.content_len > BUF_SIZE-c->response.buf.buf_len) return -4;
    va_start(args, format);
    ret = vsnprintf(c->response.buf.buf + c->response.buf.buf_len, BUF_SIZE - c->response.buf.buf_len, format, args);
    va_end(args);
    if (ret<=0) return -5;
    c->response.buf.buf_len += ret;
    return c->response.content_len + c->response.header_len;
}
/*==================================================*/
#define conn_close(c) conn_close_line(c, __LINE__)
static inline void conn_close_line(struct client_t *c, int line) {
    ((void)line);
    debugln("conn_close %d @%d", c->fd, line);
    close_socket(c->fd);
    memset(c, 0, sizeof(struct client_t)); /* ST_UNUSED */
}
/*==================================================*/
/*==================================================*/
#include <sys/stat.h>
void response_start(struct client_t *c) {
    struct stat st;
    const char *fname="output.txt";
    if(stat(fname, &st) < 0) {
        make_response(c, 404, TEXT, "file not found\n");
        return;
    }
    c->ctx = fopen(fname, "r");
    make_header(c, 200, JSON, st.st_size);
}
void response_chunk(struct client_t *c) {
    int ret = fread(c->response.buf.buf+c->response.buf.buf_len, 1, BUF_SIZE-c->response.buf.buf_len, (FILE *)c->ctx);
    if(ret>0) c->response.buf.buf_len += ret;
}
static inline void keep_alive(struct client_t *c) {
    c->state = ST_READ;
    c->tick_cnt = 0;
    memset(&c->request,0,sizeof(c->request));
    memset(&c->response,0,sizeof(c->response));
}
void response_complete(struct client_t *c) {
    if(c->ctx) fclose((FILE *)c->ctx);
    dump_client(c);
    if(c->keep_alive) keep_alive(c);
    else conn_close(c);
}
void body_start(struct client_t *c) {
    c->ctx = fopen("output.txt", "w");
}
void body_chunk(struct client_t *c) {
    fwrite(c->request.buf.buf, 1, c->request.buf.buf_len, (FILE *)c->ctx);
    c->request.buf.buf_len = 0;
}
void body_complete(struct client_t *c) {
    fclose((FILE *)c->ctx);
}
/*==================================================*/
/*==================================================*/
static int parse_header(struct client_t *c) {
    struct request_t *request = &(c->request);
    if (4 != sscanf(request->buf.buf, "%" XSTR(METHOD_LEN) "s %" XSTR(URI_LEN) "s HTTP/%d.%d\r\n", request->method, request->uri, &request->vhi, &request->vlo)) 
        return -500;
    if(request->vhi == 1 && request->vlo == 1) c->keep_alive = 1;
    const char *end = request->buf.buf + request->header_len;
    const char *line = memmem(request->buf.buf, request->buf.buf_len, "\r\n", 2);
    while (line && line < end - 2) {
        const char *next = memmem(line + 2, request->buf.buf_len-(line + 2 - request->buf.buf), "\r\n", 2);
        if (!next) break;
        if (next == line + 2) break; // empty line (end headers)
        size_t len = next - (line + 2);
        if (len < HDR_KEY_LEN + HDR_VAL_LEN) {
            if(request->nprop>=MAX_HEADERS) return -413;
            if(2 == sscanf(line + 2, "%" XSTR(HDR_KEY_LEN) "[^:]: %" XSTR(HDR_VAL_LEN) "[^ \t\r\n]", request->prop[request->nprop].key, request->prop[request->nprop].val)) {
                if (strcasecmp(request->prop[request->nprop].key, "Content-Length") == 0) {
                    request->content_len = atoi(request->prop[request->nprop].val);
                    if (request->content_len < 0) return -406;
                } else if(strcasecmp(request->prop[request->nprop].key, "Connection")==0) {
                    if(strcasecmp(request->prop[request->nprop].val, "keep-alive")==0)
                        c->keep_alive = 1;
                } else {
                    request->nprop++;
                }
            } else {
                return -406;
            }
        }
        line = next;
    }
    if (request->content_len>0) {
        request->buf.buf_len -= request->header_len;
        memmove(request->buf.buf, request->buf.buf + request->header_len, request->buf.buf_len);
    }
    return 0;
}
static void handle_write(struct client_t *c) {
    ssize_t n = RES_WRITE(c);
    if(n<0) {
        if(errno == EAGAIN || errno == EWOULDBLOCK)
            return;
        conn_close(c);
        return;
    }
    if(c->response.total_len == (c->response.content_len + c->response.header_len)) {
        debugln("response_complete %d", c->fd);
        response_complete(c); /* all send */
    } else if(c->response.buf.buf_len==0) {
        debugln("response_chunk %d", c->fd);
        response_chunk(c); /* buf empty */
    }
}
static void handle_read(struct client_t *c) {
    int n = REQ_READ(c);
    if(n==0) {
        /*peer shutdown*/
        conn_close(c);
        return;
    }
    if(n < 0) {
        if(errno == EAGAIN || errno == EWOULDBLOCK)
            return;
        conn_close(c);
        return;
    }
    if(c->request.header_len<=0) {
        char *delm = buf_find(&(c->request.buf), "\r\n\r\n", 4);
        if(delm) {
            c->request.header_len = delm - c->request.buf.buf + 4;
            c->state=ST_HEAD;
        }
    }
}
static void handle_head(struct client_t *c) {
    if(parse_header(c)<0) conn_close(c);
    if(c->request.content_len>0){
        c->state=ST_BODY;
        debugln("body_start %d", c->fd);
        body_start(c);
    } else {
        c->state=ST_WRITE;
        debugln("response_start %d", c->fd);
        response_start(c);
    }
}
static void handle_body(struct client_t *c) {
    debugln("body_chunk %d", c->fd);
    body_chunk(c);
    if((c->request.content_len+c->request.header_len)<=c->request.total_len) {
        debugln("body_complete %d", c->fd);
        body_complete(c);
        c->state=ST_WRITE;
        debugln("response_start %d", c->fd);
        response_start(c);
    }
}
/*==================================================*/
static struct client_t clients[MAX_CONNS];
static struct client_t *conn_open(int cli_sock) {
    set_sock_nonblock_nodelay(cli_sock);
    for(int i=0; i<MAX_CONNS; i++) {
        if(clients[i].state == ST_UNUSED) {
            memset(&clients[i], 0, sizeof(struct client_t));
            clients[i].fd=cli_sock;
            clients[i].state=ST_READ;
            return &clients[i];
        }
    }
    close_socket(cli_sock);
    debugln("max connection %d exceed\n", MAX_CONNS);
    return NULL;
}
static void event_loop(int listenfd) {
    memset(clients,0,sizeof(clients));
    fd_set rset,wset;
    for(;;) {
        FD_ZERO(&rset);
        FD_ZERO(&wset);
        FD_SET(listenfd, &rset);
        int maxfd=listenfd;
        for(int i=0; i<MAX_CONNS; i++) {
            struct client_t *c = &clients[i];
            switch (c->state) {
                case ST_UNUSED: continue;
                case ST_READ:
                case ST_HEAD:
                case ST_BODY:    FD_SET(c->fd, &rset); break;
                case ST_WRITE:   FD_SET(c->fd, &wset); break;
            }
            if(c->fd>maxfd) maxfd=c->fd;
        }
        struct timeval timeout = { .tv_sec = 2, .tv_usec = 0, };
        int nready = select(maxfd+1, &rset, &wset, NULL, &timeout);
        if(nready < 0) {
            perror("select");
            exit(EXIT_FAILURE);
        }
        if(nready==0) { /*timeout*/
            for(int i=0; i<MAX_CONNS; i++) {
                if(clients[i].state==ST_UNUSED) continue;
                if(++clients[i].tick_cnt>=IDLE_TIMEOUT_COUNT) conn_close(&clients[i]);
            }
            continue;
        }
        if(FD_ISSET(listenfd, &rset)) {
            int cli_sock = accept(listenfd, NULL, NULL);
            if (cli_sock == -1) {
#if defined(__WIN32__)
                if (WSAGetLastError() == WSAEWOULDBLOCK)
                    continue;
#else
                if (errno == EAGAIN || errno == EWOULDBLOCK)
                    continue;
#endif
                perror("accept");
                close_socket(listenfd);
                continue;
            }
            conn_open(cli_sock);
        }
        for(int i=0;i<MAX_CONNS;i++) {
            if(clients[i].state==ST_UNUSED) continue;
            if (clients[i].tick_cnt>=IDLE_TIMEOUT_COUNT) { conn_close(&clients[i]); continue; }
            clients[i].tick_cnt = 0; /*reset tick count*/
            if(FD_ISSET(clients[i].fd,&rset)) {
                handle_read(&clients[i]); /* read state*/
                if(clients[i].state==ST_HEAD) handle_head(&clients[i]);
                if(clients[i].state==ST_BODY) handle_body(&clients[i]);
            }
            if(clients[i].state!=ST_UNUSED && FD_ISSET(clients[i].fd,&wset)) handle_write(&clients[i]);
        }
    }
}
int main(const int argc, char const* argv[]) {
#if defined(__WIN32__)
    WSADATA wsaData;
    int iResult = WSAStartup(MAKEWORD(2 ,2), &wsaData);
    if (iResult != 0) {
        fprintf(stderr, "error at WSASturtup %d\n", iResult);
        return 0;
    }
#else
    signal(SIGPIPE, SIG_IGN);
#endif
    int srv_sock = create_tcp_server("127.0.0.1", HTTP_PORT, 10);
    if (srv_sock == -1) {
        perror("Create socket");
        exit(EXIT_FAILURE);
    }
    event_loop(srv_sock);
#if defined(__WIN32__)
    WSACleanup();
#endif
    return 0;
}
